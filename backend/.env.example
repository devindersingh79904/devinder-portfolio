APP_NAME=portfolio-api
APP_ENV=local
APP_VERSION=1.0.0

# Local (non-Docker) backend development connection string.
DATABASE_URL=postgresql+psycopg://postgres:replace-with-strong-password@localhost:5432/portfolio_db

# Must be a strong, random secret of at least 32 characters.
# Placeholders like "change-me-in-production" are rejected at startup.
JWT_SECRET_KEY=replace-with-at-least-32-character-secret
JWT_ALGORITHM=HS256
# Short-lived access token + long-lived refresh token (httpOnly cookie).
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
# Set false for local http dev so the refresh cookie is sent over http://localhost.
REFRESH_COOKIE_SECURE=true

# JD Match LLM (optional). When unset (here and in admin Settings), JD Match uses
# the offline keyword heuristic. The admin Settings page can override both at runtime.
ANTHROPIC_API_KEY=
JD_MATCH_MODEL=claude-haiku-4-5

# Comma-separated list of allowed origins, or "*" to allow all.
CORS_ALLOWED_ORIGINS=*

ENABLE_DEFAULT_SEED=true
AUTO_SEED_ON_STARTUP=false

# Optional env-driven default admin. When both email and password are set, the admin
# is auto-created on startup if it doesn't already exist. Admin URL: /admin/login
# Use a strong password and change it after first login.
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace-with-strong-admin-password
DEFAULT_ADMIN_NAME=Admin

UPLOAD_DIR=uploads/resume
MAX_RESUME_SIZE_MB=10
