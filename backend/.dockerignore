# Never bake local secrets or environment-specific config into the image.
# (A developer .env with DATABASE_URL=...@localhost would shadow the
# compose-provided ...@postgres value and break DB connectivity in containers.)
.env
.env.*
!.env.example

# Python / virtualenv / caches
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local runtime artifacts
uploads/
*.log

# VCS / editor
.git/
.gitignore
.DS_Store
