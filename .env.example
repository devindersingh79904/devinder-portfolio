# =====================================================================
# Docker Compose environment (project root).
# Copy to `.env` and fill in strong secrets before running:
#   cp .env.example .env
# docker compose reads this file automatically for ${VAR} interpolation.
# =====================================================================

# --- Database (Postgres container) ---
POSTGRES_DB=portfolio_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password

# --- Backend ---
APP_ENV=production
# REQUIRED. Strong random secret, >= 32 chars. Placeholders are rejected at startup.
# Generate one with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-at-least-32-character-secret
# Comma-separated list of allowed origins, or "*" to allow all.
CORS_ALLOWED_ORIGINS=*
ENABLE_DEFAULT_SEED=true
AUTO_SEED_ON_STARTUP=false

# --- Default admin (optional) ---
# When both are set, the admin is auto-created on startup if it doesn't exist.
# Use a strong password and change it after first login. Admin URL: /admin/login
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace-with-strong-admin-password
DEFAULT_ADMIN_NAME=Admin

# --- Frontend (baked into the build by Vite) ---
# For local Docker use the default; for cloud set your API origin,
# e.g. https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1
